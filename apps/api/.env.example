# Aegis Signal API — environment.
#
# Every value here is validated at boot by src/config/env.schema.ts. The app
# REFUSES TO START if anything is missing or malformed — a backend that boots
# with a missing DATABASE_URL and discovers it under load has merely deferred the
# crash to the worst possible moment.
#
# Never hard-code these in code (AGENTS.md §7). Coolify injects them at deploy.

NODE_ENV=development

# ── Application ──────────────────────────────────────────────────────────────
PORT=4000
# Public URL of the API. Must NOT be localhost in production — the schema checks.
APP_URL=http://localhost:4000
# Comma-separated origins allowed to call the API.
WEB_ORIGIN=http://localhost:3000
# Everything is timestamped in UTC. A server in a local timezone silently
# mis-buckets candles, and a mis-bucketed candle is a wrong signal.
TZ=UTC

# ── Data ─────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://aegis:aegis@localhost:5432/aegis
REDIS_URL=redis://localhost:6379

# ── Security ─────────────────────────────────────────────────────────────────
# Minimum 32 characters. In production the schema REJECTS anything containing
# "changeme", "secret", "development", "test" or "local" — a placeholder that
# reaches production is not a typo, it is an incident.
#   openssl rand -base64 48
JWT_SECRET=dev-only-please-generate-a-real-one-at-least-32-chars
JWT_EXPIRES=15m
# Requests per minute, per IP.
RATE_LIMIT=120

# ── Observability ────────────────────────────────────────────────────────────
LOG_LEVEL=debug

# ── Exchange ──────────────────────────────────────────────────────────────────
CCXT_TIMEOUT=15000
WS_HEARTBEAT=30000

# DNS servers for exchange hostnames ONLY. Comma-separated IPs.
#
# A development escape hatch. Many ISPs block cryptocurrency exchanges at the DNS
# layer, and the failure is indistinguishable from an exchange outage:
# api.binance.com simply does not resolve, and every adapter reports ENOTFOUND.
# Setting this routes exchange lookups — and nothing else — through a resolver
# that answers honestly. Postgres, Redis and everything else are unaffected.
#
# LEAVE THIS UNSET IN PRODUCTION. The schema refuses to boot if it is set there:
# a VPS has no reason to filter the exchanges we depend on, and hard-coding DNS
# servers we do not operate is an outage scheduled by someone else.
#
# EXCHANGE_DNS_SERVERS=1.1.1.1,8.8.8.8

# ── Integrations (optional until their milestone) ─────────────────────────────
TELEGRAM_TOKEN=
WHATSAPP_TOKEN=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
