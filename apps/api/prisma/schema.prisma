// Aegis Signal — database schema.
//
// EMPTY ON PURPOSE. Milestone 01 builds the platform, not the product; no
// application models exist yet (AGENTS.md §4).
//
// When they arrive, the entities are specified in docs/07-BACKEND_REQUIREMENTS.md §13.
// One deserves emphasis now, because it shapes the schema:
//
//   `Strategy` is ONE table holding JSON documents — built-in and user-created
//   alike. A strategy is a document, not code (ADR-023). That is why adding a
//   strategy costs a row rather than a deployment, and it is why there must
//   never be a second strategy table for "custom" ones.
//
// Two more that are easy to get wrong:
//
//   `Signal` is append-only. No signal is ever deleted (06-STRATEGIES §5).
//   `SignalOutcome` is the ledger — the only thing in this platform that earns
//   trust. Everything the confidence score claims is derived from it.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Milestone 09 — the evidence behind the confidence score.
//
// Two tables, and the distinction between them is the whole of ADR-024:
//
//   HistoricalSetup is what the MARKET did. Replayed from exchange candles,
//   labelled by walking each setup forward bar by bar. Real, and optimistic —
//   the rules were written by people who had already seen this history.
//
//   SignalOutcome (the LIVE ledger) is what WE did. It does not exist yet, and
//   it cannot: no signal has ever been published. It arrives with the Signal
//   Engine (M10) and settles thereafter. Until then live samples are ZERO, and
//   the platform says so rather than passing the replay off as a track record.
//
// The confidence engine reads the first, is built to read the second, and is
// forbidden from ever merging them behind a single unlabelled percentage.
// ─────────────────────────────────────────────────────────────────────────────

/// One historical setup, replayed and labelled. The atom of earned confidence.
///
/// Append-only, like everything that constitutes evidence. A replay that runs
/// twice must not count the same setup twice — hence the unique key on the
/// setup's identity rather than a surrogate id. Double-counted evidence is the
/// cheapest possible way to manufacture a sample size.
model HistoricalSetup {
  id String @id @default(cuid())

  /// WHICH RULES produced this. When a strategy is edited its hash changes and
  /// these rows stop matching it — ADR-024's "editing a strategy wipes its track
  /// record", enforced by arithmetic rather than by a DELETE.
  strategyId String
  rulesHash  String

  symbol    String
  exchange  String
  timeframe String
  direction String

  regime           String
  volatilityState  String
  volatilityBucket String
  liquidityBucket  String
  riskLevel        String
  patterns         String[]

  /// The raw contributor score. Its BUCKET is what gets calibrated.
  score Int

  barTime     BigInt
  entryPrice  Float
  stopPrice   Float
  targetPrice Float

  /// WIN | LOSS | EXPIRED. Expired is a non-win, never a discarded row.
  outcome   String
  realisedR Float
  barsHeld  Int

  /// CALIBRATION (older) | VALIDATION (newer). The walk-forward guard: a model
  /// is fitted on the first and graded on the second, and never the reverse.
  split String

  createdAt DateTime @default(now())

  @@unique([strategyId, rulesHash, symbol, timeframe, barTime])
  @@index([strategyId, rulesHash])
  @@index([score])
  @@index([split])
}

/// A fitted calibration model. Versioned, and NEVER overwritten.
///
/// A signal published on Tuesday claimed a number produced by Tuesday's model.
/// If Wednesday's refit replaced it in place, Tuesday's signal would be judged
/// against a model that did not exist when it spoke — and the platform's track
/// record would become unfalsifiable, which is a politer word for fictional.
model CalibrationModel {
  version Int    @id
  method  String

  /// Exactly one row may be active. Enforced in the repository, because a
  /// partial unique index is not expressible here and two active models would
  /// mean two different answers to the same question.
  active Boolean @default(false)

  /// What it was fitted on. Without this, a win rate is a rumour.
  corpus Json
  bins   Json

  plattA Float?
  plattB Float?

  /// Flattering. Reported anyway, next to the one that can embarrass it.
  inSample Json
  /// Data the model had never seen. THIS is the number that counts.
  outOfSample Json

  fittedAt  DateTime
  createdAt DateTime @default(now())

  @@index([active])
}

// ─────────────────────────────────────────────────────────────────────────────
// Milestone 10 — the Signal Engine. The publisher.
//
// A Signal is the single output of the platform (AGENTS.md §1) and it is
// APPEND-ONLY. No signal is ever deleted (06-STRATEGIES §5): its lifecycle
// advances, but the trade it described is a matter of record the instant it is
// published, because a track record you can revise is not a track record.
// ─────────────────────────────────────────────────────────────────────────────

/// A published signal — risk-validated, confidence-calibrated, selected.
///
/// The `id` is DETERMINISTIC (a hash of symbol + direction + timeframe + bar +
/// the strategies that fired), not a random UUID. That is what makes the pipeline
/// idempotent — re-running a bar cannot publish the same opportunity twice — and
/// it is what makes deduplication and deterministic replay possible at all.
model Signal {
  id String @id

  symbol    String
  exchange  String
  timeframe String
  direction String
  regime    String

  /// Every strategy that agreed, primary first. Length > 1 is confluence.
  strategies  String[]
  /// The exact rules each strategy fired on — a settled trade traces to these.
  rulesHashes String[]

  marketType       String
  suggestedLeverage Int?
  entryPrice       Float
  stopLoss         Float
  takeProfits      Float[]

  /// The three separate measures, each stored whole with its own provenance.
  confidence Json
  confluence Json
  signalScore Json

  isPrime Boolean @default(false)

  /// ACTIVE | TRIGGERED | COMPLETED | STOPPED | EXPIRED. Advances, never resets.
  status String

  barTime     BigInt
  publishedAt BigInt
  expiresAt   BigInt

  summary       String
  whyPublished  String
  supporting    String[]
  contradicting String[]
  unassessed    String[]

  /// Which calibration model produced the confidence. Stored forever, so the
  /// number this signal claimed can always be graded against the model that made
  /// it — even after the model is superseded.
  calibrationVersion Int

  createdAt DateTime @default(now())

  transitions SignalTransition[]

  @@index([status])
  @@index([symbol, direction, timeframe, barTime])
  @@index([isPrime])
  @@index([publishedAt])
}

/// Every lifecycle transition, appended. The audit trail — a signal's whole life
/// is reconstructable from these, in order, and none is ever overwritten.
model SignalTransition {
  id       String @id @default(cuid())
  signalId String
  signal   Signal @relation(fields: [signalId], references: [id])

  from String
  to   String
  /// Why it moved — "price reached TP1 at 62,400", "expired after 72 bars".
  reason String

  at        BigInt
  createdAt DateTime @default(now())

  @@index([signalId])
}

/// The day's Prime budget, as an auditable ledger row per awarded slot.
///
/// Prime is scarce on purpose (ADR-021 §2). A ledger rather than a counter so
/// that "why was this not Prime?" always has an answer: the slots were spent,
/// here is on what, in rank order. The unique key stops the same signal taking
/// two slots and stops a slot number being reused within a day.
model PrimeAllocation {
  id       String @id @default(cuid())
  day      String
  slot     Int
  signalId String
  symbol   String
  score    Float

  awardedAt BigInt
  createdAt DateTime @default(now())

  @@unique([day, slot])
  @@unique([day, signalId])
  @@index([day])
}

// ─────────────────────────────────────────────────────────────────────────────
// Milestone 11 — the Outcome Ledger. The permanent memory.
//
// Signals are temporary; history is permanent. The ledger NEVER edits history:
// a settled outcome is a matter of record, corrections are appended as new audit
// events, and nothing is ever overwritten. This is the single source of truth the
// Confidence Engine calibrates against — if it can be revised, every number
// downstream becomes a rumour (06-STRATEGIES §5).
// ─────────────────────────────────────────────────────────────────────────────

/// One published signal, recorded from birth to settlement — the immutable atom
/// of the platform's history.
///
/// It carries EVERYTHING (the confidence, confluence, risk, evidence, all frozen
/// as they were at publication) so that no downstream engine ever needs to
/// recreate the past. A recreation could differ from what happened; the past is
/// stored, not recomputed.
///
/// `settlement` is null while open and set exactly ONCE, forever, on close. The
/// one-way transition is enforced in the repository, not by a trigger, so the
/// enforcement is testable.
model LedgerEntry {
  signalId String @id

  strategyId      String
  strategyVersion Int
  rulesHash       String

  symbol    String
  exchange  String
  market    String
  timeframe String
  direction String
  regime    String

  entryPrice  Float
  stopLoss    Float
  takeProfits Float[]

  /// The three measures, frozen. The evidence that justified the trade.
  confidence  Json
  confluence  Json
  signalScore Json
  calibrationVersion Int

  publishedAt BigInt
  barTime     BigInt

  /// Null while open. The settlement arithmetic (outcome, R, PnL, MFE, MAE,
  /// duration, exit reason), set once and never touched again.
  settlement Json?
  /// Denormalised for fast filtering/sorting without parsing the JSON. Kept in
  /// lockstep with `settlement` in the same write.
  outcome   String?
  realisedR Float?
  settledAt BigInt?

  createdAt DateTime @default(now())

  audits LedgerAudit[]

  @@index([strategyId, rulesHash])
  @@index([outcome])
  @@index([settledAt])
  @@index([symbol])
  @@index([regime])
  @@index([publishedAt])
}

/// Every mutation of the ledger, appended. The audit trail — a record's whole
/// life is reconstructable from these, in order, and none is ever overwritten.
/// A correction is a NEW row, never an edit to an old one.
model LedgerAudit {
  id       String      @id @default(cuid())
  signalId String
  entry    LedgerEntry @relation(fields: [signalId], references: [signalId])

  /// CREATED | TRIGGERED | SETTLED | ARCHIVED | CORRECTION | REPLAY.
  action String
  detail String

  at        BigInt
  createdAt DateTime @default(now())

  @@index([signalId])
  @@index([action])
}

// ─────────────────────────────────────────────────────────────────────────────
// Milestone 12 — the Insights Engine. Context, never decisions.
//
// One normalized story, from one or more providers, classified deterministically.
// `dedupeKey` merges the same story across outlets; `sources` preserves them all.
// ─────────────────────────────────────────────────────────────────────────────

/// One piece of normalized market intelligence. Append-mostly: an insight can be
/// updated (a new outlet corroborates it, extending `sources`) but its
/// classification is deterministic, so a re-run produces the same verdict.
model Insight {
  id String @id

  provider String
  source   String
  sources  String[]

  title       String
  description  String
  url         String?
  language    String

  publishedAt BigInt
  collectedAt BigInt

  category String
  severity String
  impact   String

  /// Structured entities as JSON (kind/symbol/name), plus denormalised coin
  /// symbols and tags as arrays for fast filtering and search.
  entities Json
  coins    String[]
  tags     String[]

  confidence Float

  /// The fingerprint that merges the same story across providers. Unique — a
  /// second outlet running the story updates the existing row rather than adding a
  /// duplicate.
  dedupeKey String @unique

  createdAt DateTime @default(now())

  @@index([category])
  @@index([severity])
  @@index([publishedAt])
  @@index([coins])
}

// ─────────────────────────────────────────────────────────────────────────────
// Milestone 13 — the Notification Engine. The last mile.
//
// It delivers information; it decides nothing. Every delivery carries its whole
// lifecycle as a matter of record — a notification the platform cannot prove it
// delivered is one a trader cannot rely on.
// ─────────────────────────────────────────────────────────────────────────────

/// One attempt to deliver one notification to one recipient on one channel.
///
/// The `id` is DETERMINISTIC — a hash of (notification source, recipient, channel)
/// — which is what makes "exactly once" enforceable: a re-processed event yields
/// the same id and the unique key refuses the duplicate. Status transitions and
/// `attempts` are the observability the engine promises.
model Notification {
  id String @id

  type     String
  priority String
  channel  String

  recipient String
  subject   String?

  /// The rendered message (title/markdown/plain/link), frozen at render time.
  message Json

  /// QUEUED | SENDING | DELIVERED | RETRYING | FAILED | SUPPRESSED | CANCELLED | EXPIRED
  status           String
  attempts         Int     @default(0)
  providerResponse String?

  createdAt   BigInt
  scheduledFor BigInt
  deliveredAt BigInt?

  recordedAt DateTime @default(now())

  @@index([status])
  @@index([recipient])
  @@index([channel])
  @@index([type])
  @@index([createdAt])
}
